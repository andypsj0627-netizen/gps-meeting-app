{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-context.sh\"",
            "timeout": 30,
            "statusMessage": "Git 동기화 상태 확인 + 프로젝트 컨텍스트 로드 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.claude/hooks/dart-analyze.sh\"",
            "timeout": 60,
            "statusMessage": "dart analyze 실행 중..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.claude/hooks/flutter-test-gate.sh\"",
            "timeout": 300,
            "statusMessage": "flutter test 게이트 실행 중..."
          }
        ]
      }
    ]
  }
}
